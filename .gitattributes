# Keep the self-updated files byte-stable so Ed25519 signatures stay valid.
# git must NOT rewrite line endings for these, or companion.py.sig won't match the
# bytes raw.githubusercontent.com serves and clients will reject every update.
companion.py -text
companion.py.sig -text

# The C# agent's self-update manifest is signed byte-for-byte, same as companion.py.
agent/agent.manifest.json -text
agent/agent.manifest.json.sig -text
